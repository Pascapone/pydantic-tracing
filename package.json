{
  "name": "tanstack-start",
  "private": true,
  "type": "module",
  "scripts": {
    "redis:start": "docker run -d --name redis -p 6379:6379 redis:alpine",
    "redis:stop": "docker stop redis && docker rm redis",
    "dev": "vite dev --host 127.0.0.1 --port 3341 --strictPort",
    "dev:test": "vite dev --host 127.0.0.1 --port 3341 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "node scripts/e2e-preflight.mjs && playwright test --config=playwright.config.ts --project=chromium --workers=1 --reporter=line",
    "test:e2e:preflight": "node scripts/e2e-preflight.mjs",
    "test:e2e:traces": "node scripts/e2e-preflight.mjs && playwright test --config=playwright.config.ts e2e/traces.spec.ts --project=chromium --workers=1 --reporter=line",
    "test:e2e:headed": "node scripts/e2e-preflight.mjs && playwright test --config=playwright.config.ts --project=chromium --workers=1 --reporter=line --headed",
    "test:e2e:debug": "node scripts/e2e-preflight.mjs && playwright test --config=playwright.config.ts e2e/traces.spec.ts --project=chromium --workers=1 --debug",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:py": ".\\python-workers\\.venv\\Scripts\\python.exe -m pytest python-workers/tests -q -p no:cacheprovider --ignore=python-workers/tests/.tmp --ignore-glob=python-workers/tests/pytest-cache-files-*"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@uiw/react-json-view": "^2.0.0-alpha.41",
    "better-auth": "^1.4.18",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.34.1",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^11.0.4",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^27.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5"
  }
}
